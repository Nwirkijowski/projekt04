<link rel="stylesheet" href="/style.css">
<div class="main-center">
  <section class="auth-card">
    <h2>Rejestracja</h2>
    <p class="subtext">Create your account</p>
    <form method="POST">
      <label for="username">Username</label>
      <input id="username" name="username" placeholder="login" required>
      <label for="password">Password</label>
      <input id="password" type="password" name="password" placeholder="hasło" required>
      <button type="submit">Rejestracja</button>
    </form>
    <p style="text-align:center; margin-top:14px; color:#a5b0c2;">
      Already have an account? <a href="/login" style="color:#a5c9ff;">Log in</a>
    </p>
  </section>
</div>
